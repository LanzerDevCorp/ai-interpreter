# Copy this file to .env.local and fill in real values. Never commit real secrets.

# Routed automatically through the Vercel AI Gateway via OIDC -- no manual
# provider API key required for this one. Use a Gateway-style model string,
# e.g. "openai/gpt-5.4".
DEFAULT_MODEL=

# Direct Groq API key (documented OIDC exception -- Groq transcription is
# called directly via @ai-sdk/groq, not routed through the AI Gateway).
# Get a key at https://console.groq.com/keys
GROQ_API_KEY=

# Direct ElevenLabs API key (manual key, not routed through the AI Gateway --
# Gateway routes zero TTS providers). Used by @ai-sdk/elevenlabs for speech
# synthesis. Get a key at https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=

# ElevenLabs voice ID. "eleven_multilingual_v2" is a single multilingual model
# that auto-detects the spoken language, so ONE voice ID covers BOTH Korean and
# Spanish output -- no per-language voice IDs needed. Default below is "Rachel",
# a known multilingual voice; override to spot-check other voices.
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM
